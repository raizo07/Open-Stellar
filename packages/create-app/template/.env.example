# Open Stellar node environment variables
# Copy to .env.local for local development: cp .env.example .env.local

# Display name shown in the admin console header
NEXT_PUBLIC_NODE_NAME=__NODE_NAME__

# Stellar network: testnet | mainnet
STELLAR_NETWORK=__NETWORK__

# WalletConnect Cloud project ID (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Admin API key for protected routes (generated on first boot if unset)
ADMIN_API_KEY=

# Public URL of your deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000
