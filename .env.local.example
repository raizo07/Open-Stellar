# 🔐 LOCAL DEVELOPMENT ENVIRONMENT
# 
# ⚠️  SECURITY WARNING:
# - This file contains sensitive credentials
# - NEVER commit to git
# - Add to .gitignore (already done)
# - Delete after demo/development: rm .env.local
# - Use only Stellar TESTNET (never mainnet)
# 
# If secrets are leaked:
# 1. Immediately rotate keys
# 2. Audit git history: git log -p | grep ANTHROPIC_API_KEY
# 3. Check git doesn't have old commits: git log --all --oneline
# 4. Read SECURITY.md for full incident response

# Stellar Network - MUST BE 'testnet' for development
# ❌ NEVER use 'mainnet' locally - funds at risk!
STELLAR_NETWORK=testnet

# Development Mode - Disables auth, uses testnet
# Only set to 'true' if using testnet
DEV_MODE=true

# Anthropic API Key
# Get from: https://console.anthropic.com/
# Format: sk-ant-...
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Moltbot Gateway Token
# Used for internal communication
# Can be any string for development
MOLTBOT_GATEWAY_TOKEN=dev-test-token-12345

# Optional: Cloudflare Access (if using CF auth)
# Leave empty for DEV_MODE=true
CF_ACCESS_CLIENT_ID=

# Optional: Enable debug routes (/debug/*)
DEBUG_ROUTES=false

# Optional: Stellar testnet public key that receives paid cosmetic purchases
# (e.g. the 0.5 XLM agent color-change fee). Leave empty to disable paid
# customization -- equip/unequip of already-unlocked cosmetics still works.
STELLAR_TREASURY_ADDRESS=

# Optional: Better Stack / Logtail structured API logs
# Leave empty locally to keep logging as a no-op.
LOGTAIL_SOURCE_TOKEN=

# Optional: Custom EVM RPC URLs for x402 settlement
# Default BNB: https://bsc-dataseed.binance.org
# Default Base: https://mainnet.base.org
NEXT_PUBLIC_BNB_RPC_URL=
NEXT_PUBLIC_BASE_RPC_URL=

# Optional: OpenAI Alternative (if using instead of Anthropic)
# OPENAI_API_KEY=sk-...

# Optional: Telegram Bot Token
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Optional: Discord Bot Token
# DISCORD_BOT_TOKEN=...

# Optional: Slack Tokens
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ════════════════════════════════════════════════════════════════════
# BEFORE RUNNING npm run dev:
# 
# 1. Make sure this file has restricted permissions:
#    chmod 600 .env.local
#
# 2. For maximum security, use Docker:
#    docker build -f Dockerfile.dev -t open-stellar-dev .
#    docker run --rm --env-file .env.local -p 5173:5173 open-stellar-dev
#
# 3. Before demo, audit for leaks:
#    ./scripts/security-audit.sh
#
# 4. After demo, delete this file:
#    rm .env.local
# ════════════════════════════════════════════════════════════════════
